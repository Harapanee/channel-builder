{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://channel-video-factory.local/schemas/episode.schema.json",
  "title": "EpisodeFile",
  "description": "仕様書 §5.3。episodes/<epId>/episode.json(エピソード状態)。",
  "type": "object",
  "additionalProperties": false,
  "required": ["episodeId", "subject", "targetDurationSec", "status"],
  "properties": {
    "episodeId": { "type": "string", "minLength": 1 },
    "subject": { "type": "string", "minLength": 1 },
    "targetDurationSec": { "type": "number", "exclusiveMinimum": 0 },
    "status": {
      "enum": [
        "researched",
        "scripted",
        "voiced",
        "storyboarded",
        "implemented",
        "qa_passed",
        "reviewed",
        "final"
      ]
    }
  }
}
