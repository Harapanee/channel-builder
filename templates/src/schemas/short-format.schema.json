{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://channel-video-factory.local/schemas/short-format.schema.json",
  "title": "ShortFormatFile",
  "description": "channel/short-formats/<formatId>.json(ショートフォーマット契約)。機械が執行できる値のみを書く。語り口・選定基準は同名.md(教義)へ。",
  "type": "object",
  "additionalProperties": false,
  "required": ["formatId", "name", "targetDurationSec", "segments"],
  "properties": {
    "formatId": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]*$" },
    "name": { "type": "string", "minLength": 1 },
    "targetDurationSec": { "type": "number", "exclusiveMinimum": 0, "maximum": 180 },
    "segments": {
      "type": "array",
      "minItems": 2,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "role", "targetSec", "label"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "role": { "enum": ["hook", "body", "climax", "cta"] },
          "targetSec": { "type": "number", "exclusiveMinimum": 0 },
          "label": { "type": "string", "minLength": 1 }
        }
      }
    }
  }
}
