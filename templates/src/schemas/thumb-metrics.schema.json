{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "thumb-metrics.schema.json",
  "title": "サムネ計測レポート (publish/thumb-metrics.json)",
  "description": "render-thumbs.tsが書く機械計測値。合否は解像度のみ(実証済みの唯一の数値基準)。notesは3案内の相対警告(情報提供)。thumb-test.jsonの勝敗と突合して勝ちパターン分析(channel-refine)に使う。",
  "type": "object",
  "required": ["episodeId", "generatedAt", "variants"],
  "additionalProperties": false,
  "properties": {
    "episodeId": { "type": "string" },
    "generatedAt": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$",
      "description": "計測日 YYYY-MM-DD"
    },
    "variants": {
      "type": "array",
      "minItems": 1,
      "maxItems": 3,
      "items": {
        "type": "object",
        "required": [
          "id",
          "file",
          "width",
          "height",
          "rmsContrast",
          "colorfulness",
          "meanLuminance",
          "notes"
        ],
        "additionalProperties": false,
        "properties": {
          "id": { "type": "string" },
          "file": { "type": "string" },
          "width": { "type": "integer" },
          "height": { "type": "integer" },
          "rmsContrast": {
            "type": "number",
            "description": "輝度(0〜1)の標準偏差"
          },
          "colorfulness": {
            "type": "number",
            "description": "Hasler-Süsstrunk指標(0〜255系)"
          },
          "meanLuminance": { "type": "number", "minimum": 0, "maximum": 1 },
          "notes": {
            "type": "array",
            "items": { "enum": ["lowestContrast", "quadrantMismatch"] }
          }
        }
      }
    }
  }
}
